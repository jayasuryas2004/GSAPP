# =====================================================
# GSAPP Backend - Environment Configuration Template
# =====================================================
#
# Copy this to .env in the same directory (backend/)
# Then fill in your actual Supabase credentials
#
# IMPORTANT: .env file is NEVER committed to GitHub (in .gitignore)
#

# =====================================================
# SUPABASE CONFIGURATION
# =====================================================
# These credentials are from your Supabase project
# Get them from: https://app.supabase.com/projects

# Your Supabase project URL
# Example: https://wtpwlxocljrrtsecxtsd.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Service Key (SECRET - DO NOT SHARE)
# This key has FULL access to your database
# Found in Supabase Dashboard: Settings → API → Service Key
# Use the "service-role" key, NOT the "anon" key
SUPABASE_SERVICE_KEY=sb_secret_YourServiceKeyHere


# =====================================================
# APPLICATION CONFIGURATION
# =====================================================

# Environment: development, staging, or production
# - development: Debug=true, verbose logging
# - production: Debug=false, quiet logging
ENVIRONMENT=development

# Debug mode
# - True: Show detailed error messages, auto-reload
# - False: Production mode, minimal error details
DEBUG=true

# API Port (used when running locally)
# When deployed to Railway, this is overridden
PORT=8000


# =====================================================
# CACHE CONFIGURATION
# =====================================================

# How long to cache scheme listings (in seconds)
# 3600 = 1 hour (default)
# Use lower value for development (60 = 1 minute)
# Use higher value for production (7200 = 2 hours)
CACHE_TTL_SECONDS=3600

# Maximum items to cache in memory
# Each scheme ~5KB, so 1000 schemes = ~5MB RAM
CACHE_MAX_ITEMS=1000


# =====================================================
# LOGGING CONFIGURATION
# =====================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (relative to backend/)
# Leave empty to disable file logging
LOG_FILE=app.log


# =====================================================
# SECURITY CONFIGURATION
# =====================================================

# Allowed origins for CORS (comma-separated)
# Already includes localhost and emulator by default
# For Railway production: https://your-railway-app.railway.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://10.0.2.2:8000

# API Key (optional - for future API authentication)
# Leave empty if not needed yet
API_KEY=


# =====================================================
# DEPLOYMENT CONFIGURATION (Railway)
# =====================================================

# Set to "railway" when deployed on Railway
# This enables Railway-specific configurations
PLATFORM=local

# Railway App Name (auto-set on Railway)
# Leave empty locally
RAILWAY_APP_NAME=


# =====================================================
# INSTRUCTIONS FOR SETUP
# =====================================================
#
# 1. Save this file as: backend/.env
#
# 2. Fill in SUPABASE_URL and SUPABASE_SERVICE_KEY:
#    - Go to: https://app.supabase.com/projects
#    - Click your GSAPP project
#    - Go to: Settings → API
#    - Copy "Project URL" → SUPABASE_URL
#    - Copy "service_role secret" → SUPABASE_SERVICE_KEY
#
# 3. Test locally:
#    python main.py
#
# 4. Visit:
#    http://localhost:8000/api/docs
#
# 5. For Railway deployment:
#    - Copy all non-empty values
#    - Add them to Railway Dashboard: Variables
#    - Re-deploy
#
# =====================================================
